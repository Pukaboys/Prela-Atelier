{
  "expo": {
    "name": "Prela Atelier",
    "slug": "prela-atelier",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F0EB"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.prelaatelier.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used for product imagery",
        "NSPhotoLibraryUsageDescription": "Used for uploading order photos",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5F0EB"
      },
      "package": "com.prelaatelier.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#C8A96E",
          "sounds": []
        }
      ]
    ],
    "scheme": "prelaatelier",
    "extra": {
      "eas": {
        "projectId": "3bf5a86a-1f84-4985-8e98-40fa3e4ed9df"
      }
    }
  }
}
