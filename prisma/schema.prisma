generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────────────────────────

enum OrderStatus {
  pending
  confirmed
  shipped
  delivered
  cancelled
}

enum BespokeEnquiryStatus {
  new
  read
  replied
  closed
}

// PromoType stored as VARCHAR in DB — validated at app layer via Zod
// enum PromoType { percentage fixed }

// ── Models ─────────────────────────────────────────────────────────────────

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique @db.VarChar(100)
  password  String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("admins")
}

model Product {
  id          Int            @id @default(autoincrement())
  name        String         @db.VarChar(255)
  slug        String         @unique @db.VarChar(255)
  description String?        @db.Text
  priceEur    Decimal        @map("price_eur") @db.Decimal(10, 2)
  imagePath   String?        @map("image_path") @db.VarChar(500)
  badge       String?        @db.VarChar(50)
  stock       Int            @default(99)
  featured    Boolean        @default(false)
  materialId  Int?           @map("material_id")
  material    Material?      @relation(fields: [materialId], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now()) @map("created_at")
  orderItems  OrderItem[]
  images      ProductImage[]

  @@map("products")
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int     @map("product_id")
  url       String  @db.VarChar(500)
  sortOrder Int     @default(0) @map("sort_order")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Order {
  id            Int         @id @default(autoincrement())
  orderCode     String      @unique @map("order_code") @db.VarChar(20)
  customerName  String      @map("customer_name") @db.VarChar(255)
  customerEmail String      @map("customer_email") @db.VarChar(255)
  customerPhone String?     @map("customer_phone") @db.VarChar(50)
  address       String      @db.Text
  city          String      @db.VarChar(100)
  postcode      String      @db.VarChar(20)
  country       String      @default("France") @db.VarChar(100)
  subtotal      Decimal     @db.Decimal(10, 2)
  shipping      Decimal     @default(0) @db.Decimal(10, 2)
  total         Decimal     @db.Decimal(10, 2)
  status        OrderStatus @default(pending)
  notes         String?     @db.Text
  promoCode     String?     @map("promo_code") @db.VarChar(50)
  discount      Decimal     @default(0) @db.Decimal(10, 2)
  createdAt     DateTime    @default(now()) @map("created_at")
  items         OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int      @map("order_id")
  productId Int?     @map("product_id")
  name      String   @db.VarChar(255)
  priceEur  Decimal  @map("price_eur") @db.Decimal(10, 2)
  quantity  Int      @default(1)
  subtotal  Decimal  @db.Decimal(10, 2)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("order_items")
}

model Material {
  id            Int       @id @default(autoincrement())
  name          String    @db.VarChar(100)
  origin        String    @db.VarChar(100)
  description   String    @db.Text
  hardness      String?   @db.VarChar(50)
  tone          String?   @db.VarChar(50)
  veining       String?   @db.VarChar(50)
  pricePerM2Eur Decimal?  @map("price_per_square_meter") @db.Decimal(10, 2)
  imagePath     String?   @map("image_path") @db.VarChar(500)
  sortOrder     Int       @default(0) @map("sort_order")
  visible       Boolean   @default(true)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  products      Product[]

  @@map("materials")
}

model BespokeEnquiry {
  id          Int                  @id @default(autoincrement())
  name        String               @db.VarChar(150)
  email       String               @db.VarChar(150)
  type        String?              @db.VarChar(100)
  budget      String?              @db.VarChar(100)
  description String               @db.Text
  timeline    String?              @db.VarChar(200)
  status      BespokeEnquiryStatus @default(new)
  notes       String?              @db.Text
  createdAt   DateTime             @default(now()) @map("created_at")

  @@map("bespoke_enquiries")
}

model PromoCode {
  id        Int       @id @default(autoincrement())
  code      String    @unique @db.VarChar(50)
  type      String    @db.VarChar(20)
  value     Decimal   @db.Decimal(10, 2)
  minOrder  Decimal   @default(0) @map("min_order") @db.Decimal(10, 2)
  maxUses   Int?      @map("max_uses")
  usedCount Int       @default(0) @map("used_count")
  expiresAt DateTime? @map("expires_at")
  active    Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("promo_codes")
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  email     String   @db.VarChar(255)
  subject   String?  @db.VarChar(100)
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}

model Setting {
  key       String   @id @db.VarChar(100)
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
