# Database
# Prisma Postgres (db.prisma.io) or any standard PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Session
# Must be at least 32 characters. Generate with: openssl rand -base64 32
SESSION_SECRET="replace-this-with-a-random-32-char-secret-key!!"

# App
NEXT_PUBLIC_APP_URL="https://yourdomain.com"
NODE_ENV="production"

# Visa Click to Pay / Visa Developer sandbox
# Server-only. Do not expose these as NEXT_PUBLIC_* values.
VISA_API_BASE_URL="https://sandbox.api.visa.com"
VISA_API_USERNAME="your-visa-project-username"

# Local development: use private files outside git.
VISA_CLIENT_CERT_PATH="./secrets/visa/cert.pem"
VISA_CLIENT_KEY_PATH="./secrets/visa/private-key.pem"
VISA_CLIENT_KEY_PASSPHRASE=""
VISA_CA_BUNDLE_PATH="./secrets/visa/visa-ca-bundle.pem"

# Vercel/production: paste PEM contents into server-only environment variables.
# Use either *_PATH values or *_PEM values. Do not use NEXT_PUBLIC_*.
VISA_CLIENT_CERT_PEM=""
VISA_CLIENT_KEY_PEM=""
VISA_CA_BUNDLE_PEM=""

# Email / SMTP (Hostinger)
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="hello@prela-atelier.com"
SMTP_PASS="your-email-password"
ADMIN_EMAIL="hello@prela-atelier.com"
