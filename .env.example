# Database
# Prisma Postgres (db.prisma.io) or any standard PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Session
# Must be at least 32 characters. Generate with: openssl rand -base64 32
SESSION_SECRET="replace-this-with-a-random-32-char-secret-key!!"

# App
NEXT_PUBLIC_APP_URL="https://yourdomain.com"
NODE_ENV="production"

# POK Pay
# Production: https://api.pokpay.io
# Staging:    https://api-staging.pokpay.io
POKPAY_API_BASE="https://api.pokpay.io"
POKPAY_KEY_ID="your-pokpay-key-id"
POKPAY_KEY_SECRET="your-pokpay-key-secret"
POKPAY_MERCHANT_ID="your-pokpay-merchant-id"
# Optional, if POK enables webhooks for your merchant account
POKPAY_WEBHOOK_URL=""
# Also accepted: POK_API_BASE, POK_KEY_ID, POK_KEY_SECRET, POK_MERCHANT_ID, POK_WEBHOOK_URL

# Email / SMTP (Hostinger)
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="hello@prela-atelier.com"
SMTP_PASS="your-email-password"
ADMIN_EMAIL="hello@prela-atelier.com"
