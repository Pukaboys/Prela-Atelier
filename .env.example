# ─── Database ───────────────────────────────────────────────────────
# Prisma Postgres (db.prisma.io) or any standard PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# ─── Session ─────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -base64 32
SESSION_SECRET="replace-this-with-a-random-32-char-secret-key!!"

# ─── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://yourdomain.com"
NODE_ENV="production"

# ─── PayPal ──────────────────────────────────────────────────────────
# Get these from https://developer.paypal.com → Apps & Credentials
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_SECRET="your-paypal-secret"
NEXT_PUBLIC_PAYPAL_CLIENT_ID="your-paypal-client-id"
# Sandbox (default): https://api-m.sandbox.paypal.com
# Live:              https://api-m.paypal.com
PAYPAL_API_BASE="https://api-m.paypal.com"

# ─── Email / SMTP (Hostinger) ─────────────────────────────────────────
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="hello@prela-atelier.com"
SMTP_PASS="your-email-password"
ADMIN_EMAIL="hello@prela-atelier.com"
